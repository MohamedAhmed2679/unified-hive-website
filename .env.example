# ─── Unified Hive Environment Variables ───

# ── EmailJS (for Contact Form → info@unifiedhive.com) ──
# Create a free account at https://emailjs.com
# Then create a service, template, and get your public key
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ── Supabase (existing — for newsletter, auth, analytics) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Google Maps (optional — only if using JS API instead of iframe) ──
# VITE_GOOGLE_MAPS_API_KEY=

# ── Optional Public APIs ──
# Email validation (Abstract API or similar)
# VITE_EMAIL_VALIDATION_API_KEY=
